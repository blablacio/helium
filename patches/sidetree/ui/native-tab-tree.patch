+#include <algorithm>
+#include <map>
+#include <string>
+#include <utility>
+
+#include "chrome/browser/ui/browser_window/public/browser_window_interface.h"
+#include "chrome/browser/ui/views/tabs/sidetree/sidetree_workspace_state.h"
+#include "components/prefs/pref_service.h"
