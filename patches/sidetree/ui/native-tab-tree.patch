+  void OnCreateContainerPressed() {
+    editor_state_ = {.kind = EditorState::Kind::kContainer, .created = true};
+    draft_container_title_.clear();
+    draft_container_color_.clear();
+    draft_container_icon_.clear();
+    EnsureContainerDraft();
+    RebuildContents();
+  }
