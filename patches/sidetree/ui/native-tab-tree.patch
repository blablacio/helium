+  cc::PaintFlags flags;
+  flags.setStyle(cc::PaintFlags::kFill_Style);
+  flags.setColor(SkColorSetA(cp->GetColor(kColorToolbarButtonIcon), 0x99));
+  flags.setAntiAlias(true);
+  canvas->DrawRoundRect(gfx::RectF(line_bounds), kDropLineThickness / 2.0f,
+                        flags);
