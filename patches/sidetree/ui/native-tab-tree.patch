+        kManagementPickerCornerRadius));
+    button->SetBorder(views::CreateRoundedRectBorder(
+        1, kManagementPickerCornerRadius,
+        checked ? SkColorSetA(accent, 0x7a) : SkColorSetA(accent, 0x34)));
