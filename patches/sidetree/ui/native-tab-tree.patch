+      .id = id,
+      .title = title,
+      .color = "blue",
+      .icon = "circle",
+      .partition_domain = "sidetreecontainer",
+      .partition_name = partition_name,
+      .disabled = disabled,
+      .tombstoned = tombstoned,
+  };
+}
