+    }
+  } else if (was_pressed) {
+    base::WeakPtr<SideTreeTabRowView> weak_this =
+        weak_ptr_factory_.GetWeakPtr();
+    Activate();
+    if (!weak_this) {
+      return;
+    }
+  }
+
   views::View::OnMouseReleased(event);
