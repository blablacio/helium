+            &SideTreeManagementContentsView::ApplyContainerEditorAndClose,
+            base::Unretained(this)));
+
+    if (created && editor_name_field_) {
+      editor_name_field_->RequestFocus();
+      editor_name_field_->SelectAll(false);
+    }
+  }
