+void SideTreeTabStripView::UpdateSearchFieldVisibility() {
+  if (!search_field_) {
+    return;
+  }
+  if (compact_mode_) {
+    search_field_->SetVisible(false);
+    if (clear_search_button_) {
+      clear_search_button_->SetVisible(false);
